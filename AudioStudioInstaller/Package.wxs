<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

    <!-- Installer Package with .NET Detection -->
    <Package Name="AudioStudio Demo"
             Manufacturer="AudioStudio"
             Version="1.0.0.0"
             UpgradeCode="7c5e1f2a-8b4d-4e3f-a2b1-c9d0e5f6a7b3"
             Compressed="yes"
             InstallerVersion="500"
             InstallerExePrivileges="elevated">
        
        <MajorUpgrade DowngradeErrorMessage="Более новая версия уже установлена." />
        <MediaTemplate EmbedCab="yes" />
        
        <Icon Id="AppIcon" SourceFile="..\AudioStudio\app.ico" />

        <!-- Use standard InstallDir UI with Russian localization -->
        <UIRef Id="WixUI_InstallDir" />

        <!-- Localized strings -->
        <ui:WixUI Id="WixUI_InstallDir"
                  InstallDirDlgTitle="Выберите папку установки"
                  InstallDirDlgDescription="Выберите папку для установки AudioStudio Demo"
                  BrowseDlgTitle="Выберите папку"
                  BrowseDlgDescription="Выберите папку для установки" />

        <Icon Id="Icon" SourceFile="..\AudioStudio\app.ico" />
        <Binary Id="IconBinary" SourceFile="..\AudioStudio\app.ico" />

        <Feature Id="ProductFeature" Title="AudioStudio Demo" Level="1">
            <ComponentGroupRef Id="ProductComponents" />
            <ComponentRef Id="DesktopShortcutComponent" Condition="CREATE_DESKTOP_SHORTCUT" />
            <ComponentRef Id="StartMenuShortcutComponent" Condition="CREATE_START_MENU_SHORTCUT" />
        </Feature>

        <StandardDirectory Id="ProgramFiles64Folder">
            <Directory Id="INSTALLFOLDER" Name="AudioStudio Demo" />
        </StandardDirectory>

        <StandardDirectory Id="ProgramMenuFolder">
            <Directory Id="AppMenuFolder" Name="AudioStudio Demo" />
        </StandardDirectory>

        <StandardDirectory Id="DesktopFolder" />

        <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
            <!-- Main executable -->
            <Component Id="MainExe" Guid="{11111111-1111-1111-1111-111111111111}">
                <File Source="..\AudioStudio\publish\AudioStudio.exe" KeyPath="yes">
                    <Shortcut Id="DesktopShortcut" Directory="DesktopFolder" Name="AudioStudio Demo"
                              WorkingDirectory="INSTALLFOLDER" Icon="Icon"
                              Condition="CREATE_DESKTOP_SHORTCUT" />
                    <Shortcut Id="StartMenuShortcut" Directory="AppMenuFolder" Name="AudioStudio Demo"
                              WorkingDirectory="INSTALLFOLDER" Icon="Icon"
                              Condition="CREATE_START_MENU_SHORTCUT" />
                </File>
            </Component>
            
            <!-- Application DLL -->
            <Component Id="AudioStudioDll" Guid="{22222222-2222-2222-2222-222222222222}">
                <File Source="..\AudioStudio\publish\AudioStudio.dll" />
            </Component>
            
            <!-- Configuration -->
            <Component Id="DepsJson" Guid="{33333333-3333-3333-3333-333333333333}">
                <File Source="..\AudioStudio\publish\AudioStudio.deps.json" />
            </Component>
            
            <Component Id="RuntimeConfig" Guid="{44444444-4444-4444-4444-444444444444}">
                <File Source="..\AudioStudio\publish\AudioStudio.runtimeconfig.json" />
            </Component>
            
            <!-- .NET Runtime -->
            <Component Id="CoreClr" Guid="{55555555-5555-5555-5555-555555555555}">
                <File Source="..\AudioStudio\publish\coreclr.dll" />
            </Component>
            
            <Component Id="ClrJit" Guid="{66666666-6666-6666-6666-666666666666}">
                <File Source="..\AudioStudio\publish\clrjit.dll" />
            </Component>
            
            <Component Id="HostFxr" Guid="{77777777-7777-7777-7777-777777777777}">
                <File Source="..\AudioStudio\publish\hostfxr.dll" />
            </Component>
            
            <Component Id="HostPolicy" Guid="{88888888-8888-8888-8888-888888888888}">
                <File Source="..\AudioStudio\publish\hostpolicy.dll" />
            </Component>
            
            <Component Id="Createdump" Guid="{99999999-9999-9999-9999-999999999999}">
                <File Source="..\AudioStudio\publish\createdump.exe" />
            </Component>
            
            <Component Id="Clretwrc" Guid="{AAAAAAAA-AAAA-AAAA-AAAA-AAAAAAAAAAAA}">
                <File Source="..\AudioStudio\publish\clretwrc.dll" />
            </Component>
            
            <Component Id="Clrgcexp" Guid="{BBBBBBBB-BBBB-BBBB-BBBB-BBBBBBBBBBBB}">
                <File Source="..\AudioStudio\publish\clrgcexp.dll" />
            </Component>
            
            <Component Id="Clrgc" Guid="{CCCCCCCC-CCCC-CCCC-CCCC-CCCCCCCCCCCC}">
                <File Source="..\AudioStudio\publish\clrgc.dll" />
            </Component>
            
            <!-- Graphics -->
            <Component Id="D3DCompiler" Guid="{DDDDDDDD-DDDD-DDDD-DDDD-DDDDDDDDDDDD}">
                <File Source="..\AudioStudio\publish\D3DCompiler_47_cor3.dll" />
            </Component>
            
            <Component Id="DirectWrite" Guid="{EEEEEEEE-EEEE-EEEE-EEEE-EEEEEEEEEEEE}">
                <File Source="..\AudioStudio\publish\DirectWriteForwarder.dll" />
            </Component>
            
            <Component Id="Accessibility" Guid="{FFFFFFFF-FFFF-FFFF-FFFF-FFFFFFFFFFFF}">
                <File Source="..\AudioStudio\publish\Accessibility.dll" />
            </Component>
            
            <!-- Czech resources -->
            <Component Id="CsResources" Guid="{12345678-1234-1234-1234-123456789012}">
                <File Source="..\AudioStudio\publish\cs\PresentationCore.resources.dll" />
                <File Source="..\AudioStudio\publish\cs\PresentationFramework.resources.dll" />
                <File Source="..\AudioStudio\publish\cs\PresentationUI.resources.dll" />
                <File Source="..\AudioStudio\publish\cs\ReachFramework.resources.dll" />
                <File Source="..\AudioStudio\publish\cs\System.Windows.Controls.Ribbon.resources.dll" />
                <File Source="..\AudioStudio\publish\cs\System.Windows.Forms.resources.dll" />
                <File Source="..\AudioStudio\publish\cs\System.Windows.Forms.Primitives.resources.dll" />
                <File Source="..\AudioStudio\publish\cs\System.Windows.Input.Manipulations.resources.dll" />
                <File Source="..\AudioStudio\publish\cs\System.Xaml.resources.dll" />
                <File Source="..\AudioStudio\publish\cs\UIAutomationClient.resources.dll" />
                <File Source="..\AudioStudio\publish\cs\UIAutomationClientSideProviders.resources.dll" />
                <File Source="..\AudioStudio\publish\cs\UIAutomationProvider.resources.dll" />
                <File Source="..\AudioStudio\publish\cs\UIAutomationTypes.resources.dll" />
                <File Source="..\AudioStudio\publish\cs\WindowsBase.resources.dll" />
                <File Source="..\AudioStudio\publish\cs\Microsoft.VisualBasic.Forms.resources.dll" />
                <File Source="..\AudioStudio\publish\cs\System.Windows.Forms.Design.resources.dll" />
            </Component>
            
            <!-- German resources -->
            <Component Id="DeResources" Guid="{23456789-2345-2345-2345-234567890123}">
                <File Source="..\AudioStudio\publish\de\PresentationCore.resources.dll" />
                <File Source="..\AudioStudio\publish\de\PresentationFramework.resources.dll" />
                <File Source="..\AudioStudio\publish\de\PresentationUI.resources.dll" />
                <File Source="..\AudioStudio\publish\de\ReachFramework.resources.dll" />
