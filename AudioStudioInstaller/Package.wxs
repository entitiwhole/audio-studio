        <!-- Desktop shortcut component -->
        <Component Id="DesktopShortcutComponent" Guid="{789ABCDE-7890-7890-7890-7890ABCDEF12}" Directory="DesktopFolder">
            <Shortcut Id="DesktopShortcutLink"
                      Name="AudioStudio Demo"
                      Description="Audio editing software"
                      Target="[INSTALLFOLDER]AudioStudio.exe"
                      WorkingDirectory="INSTALLFOLDER"
                      Icon="Icon" />
            <RegistryValue Root="HKCU" Key="Software\AudioStudio\Shortcuts" Name="Desktop" Type="integer" Value="1" KeyPath="yes" />
        </Component>

        <!-- Start menu shortcut component -->
        <Component Id="StartMenuShortcutComponent" Guid="{89ABCDEF-8901-8901-8901-8901ABCDEF23}" Directory="AppMenuFolder">
            <Shortcut Id="StartMenuShortcutLink"
                      Name="AudioStudio Demo"
                      Description="Audio editing software"
                      Target="[INSTALLFOLDER]AudioStudio.exe"
                      WorkingDirectory="INSTALLFOLDER"
                      Icon="Icon" />
            <RemoveFolder Id="RemoveAppFolder" On="uninstall" />
            <RegistryValue Root="HKCU" Key="Software\AudioStudio\Shortcuts" Name="StartMenu" Type="integer" Value="1" KeyPath="yes" />
        </Component>

        <!-- Properties -->
        <Property Id="CREATE_DESKTOP_SHORTCUT" Value="1" />
        <Property Id="CREATE_START_MENU_SHORTCUT" Value="1" />
        <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
        <Property Id="INSTALLFOLDER" Value="[ProgramFiles64Folder]AudioStudio Demo" />

        <!-- Detect .NET 10 Desktop Runtime -->
        <util:RegistrySearch Id="NetDesktop10Check"
                            Variable="NET10DESKTOP_INSTALLED"
                            Root="HKLM"
                            Key="SOFTWARE\dotnet\Setup\InstalledVersions\x64\sharedfx\Microsoft.WindowsDesktop.App"
                            Value="10.0"
                            Format="Version"
                            Comparison="greaterThanOrEqual"
                            VariableValue="0" />

    </Package>
</Wix>