                <File Source="..\AudioStudio\publish\es\System.Windows.Forms.Design.resources.dll" />
            </Component>
            
            <!-- French resources -->
            <Component Id="FrResources" Guid="{456789AB-4567-4567-4567-456789ABCDEF}">
                <File Source="..\AudioStudio\publish\fr\PresentationCore.resources.dll" />
                <File Source="..\AudioStudio\publish\fr\PresentationFramework.resources.dll" />
