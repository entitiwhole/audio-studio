<Window x:Class="AudioStudio.InstrumentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Instruments"
        Height="500" Width="550"
        WindowStartupLocation="CenterOwner"
        Background="#FF252526">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock x:Name="TrackInfoText" Grid.Row="0" Text="Track: None" 
                   Foreground="#FF888888" FontSize="14" Margin="0,0,0,10"/>
        
        <!-- Mixer -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
            <StackPanel Margin="20,0">
                <TextBlock Text="VOLUME" Foreground="#FF888888" FontSize="10"/>
                <Slider x:Name="VolumeSlider" Minimum="0" Maximum="200" Value="100" 
                        Width="120" Margin="0,5" ValueChanged="VolumeChanged"/>
                <TextBlock x:Name="VolumeText" Text="100%" Foreground="#FF7881FF"/>
            </StackPanel>
            
            <StackPanel Margin="20,0">
                <TextBlock Text="PAN" Foreground="#FF888888" FontSize="10"/>
                <Slider x:Name="PanSlider" Minimum="-100" Maximum="100" Value="0" 
                        Width="120" Margin="0,5" ValueChanged="PanChanged"/>
                <TextBlock x:Name="PanText" Text="CENTER" Foreground="#FF7881FF"/>
            </StackPanel>
        </StackPanel>
        
        <!-- Effects -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Filters -->
                <Border Background="#FF2D2D30" BorderBrush="#FF3E3E42" BorderThickness="1" 
                        CornerRadius="5" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="FILTERS" Foreground="#FFAAAAFF" FontWeight="Bold" Margin="0,0,0,10"/>
                        
                        <CheckBox x:Name="LowPassCheck" Content="Low Pass" Foreground="#FFCCCCCC" 
                                  Margin="0,5" Click="LowPassClick"/>
                        <StackPanel Orientation="Horizontal" Margin="20,0,0,5">
                            <TextBlock Text="Cutoff:" Foreground="#FF888888" Width="60"/>
                            <Slider x:Name="LowPassSlider" Minimum="200" Maximum="20000" Value="5000" Width="150" ValueChanged="LowPassChanged"/>
                            <TextBlock x:Name="LowPassText" Text="5000 Hz" Foreground="#FF7881FF" Width="70" Margin="10,0,0,0"/>
                        </StackPanel>
                        
                        <CheckBox x:Name="HighPassCheck" Content="High Pass" Foreground="#FFCCCCCC" 
                                  Margin="0,5" Click="HighPassClick"/>
                        <StackPanel Orientation="Horizontal" Margin="20,0,0,5">
                            <TextBlock Text="Cutoff:" Foreground="#FF888888" Width="60"/>
                            <Slider x:Name="HighPassSlider" Minimum="20" Maximum="5000" Value="200" Width="150" ValueChanged="HighPassChanged"/>
                            <TextBlock x:Name="HighPassText" Text="200 Hz" Foreground="#FF7881FF" Width="70" Margin="10,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Effects -->
                <Border Background="#FF2D2D30" BorderBrush="#FF3E3E42" BorderThickness="1" 
                        CornerRadius="5" Padding="10">
                    <StackPanel>
                        <TextBlock Text="EFFECTS" Foreground="#FFAAAAFF" FontWeight="Bold" Margin="0,0,0,10"/>
                        
                        <CheckBox x:Name="GainCheck" Content="Gain" Foreground="#FFCCCCCC" 
                                  Margin="0,5" Click="GainClick"/>
                        <StackPanel Orientation="Horizontal" Margin="20,0,0,5">
                            <TextBlock Text="Level:" Foreground="#FF888888" Width="60"/>
                            <Slider x:Name="GainSlider" Minimum="-20" Maximum="20" Value="0" Width="150" ValueChanged="GainChanged"/>
                            <TextBlock x:Name="GainText" Text="0 dB" Foreground="#FF7881FF" Width="70" Margin="10,0,0,0"/>
                        </StackPanel>
                        
                        <CheckBox x:Name="EchoCheck" Content="Echo / Delay" Foreground="#FFCCCCCC" 
                                  Margin="0,10,0,5" Click="EchoClick"/>
                        <Grid Margin="20,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Delay" Foreground="#FF888888" FontSize="10"/>
                                <Slider x:Name="EchoDelaySlider" Minimum="50" Maximum="1000" Value="300" ValueChanged="EchoChanged"/>
                                <TextBlock x:Name="EchoDelayText" Text="300 ms" Foreground="#FF7881FF" FontSize="10"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Feedback" Foreground="#FF888888" FontSize="10"/>
                                <Slider x:Name="EchoFeedbackSlider" Minimum="0" Maximum="90" Value="30" ValueChanged="EchoChanged"/>
                                <TextBlock x:Name="EchoFeedbackText" Text="30%" Foreground="#FF7881FF" FontSize="10"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Mix" Foreground="#FF888888" FontSize="10"/>
                                <Slider x:Name="EchoMixSlider" Minimum="0" Maximum="100" Value="30" ValueChanged="EchoChanged"/>
                                <TextBlock x:Name="EchoMixText" Text="30%" Foreground="#FF7881FF" FontSize="10"/>
                            </StackPanel>
                        </Grid>
                        
                        <CheckBox x:Name="ReverbCheck" Content="Reverb" Foreground="#FFCCCCCC" 
                                  Margin="0,10,0,5" Click="ReverbClick"/>
                        <Grid Margin="20,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Wet" Foreground="#FF888888" FontSize="10"/>
                                <Slider x:Name="ReverbWetSlider" Minimum="0" Maximum="100" Value="30" ValueChanged="ReverbChanged"/>
                                <TextBlock x:Name="ReverbWetText" Text="30%" Foreground="#FF7881FF" FontSize="10"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Room" Foreground="#FF888888" FontSize="10"/>
                                <Slider x:Name="ReverbRoomSlider" Minimum="0" Maximum="100" Value="50" ValueChanged="ReverbChanged"/>
                                <TextBlock x:Name="ReverbRoomText" Text="50%" Foreground="#FF7881FF" FontSize="10"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Width="100" Margin="0,0,10,0" Click="CancelClick"/>
            <Button Content="Apply" Width="100" Background="#FF4CAF50" Foreground="White" Click="ApplyClick"/>
        </StackPanel>
    </Grid>
</Window>
