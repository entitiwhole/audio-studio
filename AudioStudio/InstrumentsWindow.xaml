<Window x:Class="AudioStudio.InstrumentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Instruments"
        Height="550" Width="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="Transparent"
        ResizeMode="CanResize">

    <WindowChrome.WindowChrome>
        <WindowChrome CornerRadius="5" 
                      GlassFrameThickness="0" 
                      ResizeBorderThickness="5"
                      CaptionHeight="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFAAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TrackSlider" TargetType="Slider">
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="4" Background="#FF3E3E42" CornerRadius="2" VerticalAlignment="Center"/>
                            <Border Height="4" Background="#FF7881FF" CornerRadius="2" VerticalAlignment="Center" 
                                    HorizontalAlignment="Left">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource SliderToWidthConverter}">
                                        <Binding Path="Value" RelativeSource="{RelativeSource TemplatedParent}"/>
                                        <Binding Path="Minimum" RelativeSource="{RelativeSource TemplatedParent}"/>
                                        <Binding Path="Maximum" RelativeSource="{RelativeSource TemplatedParent}"/>
                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource TemplatedParent}"/>
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Width="14" Height="14">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="#FF7881FF" Width="14" Height="14"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Основной контейнер -->
    <Border Background="#FF252526" CornerRadius="5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="0"/>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Resize region top -->
            <!-- <Border Grid.Row="0" Background="Transparent" Cursor="SizeNS" 
                    MouseLeftButtonDown="Window_MouseLeftButtonDown"/> -->

            <!-- Header -->
            <Border Grid.Row="1" Background="#FF1A1A2E" CornerRadius="5,5,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                        <TextBlock Text="🎹" FontSize="14" Foreground="#FF7881FF" Margin="0,0,8,0"/>
                        <TextBlock Text="Instruments" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>

                    <Button Grid.Column="1" Content="✕" Style="{StaticResource CloseButton}" 
                            Click="Close_Click" Margin="0,0,2,0"/>
                </Grid>
            </Border>

            <!-- Main content - Track-style panel -->
            <Border Grid.Row="2" Background="#FF1E1E1E" Margin="8">
                <Border BorderBrush="#FF3E3E42" BorderThickness="1" CornerRadius="4">
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Track info -->
                        <TextBlock x:Name="TrackInfoText" Grid.Row="0" Text="Track: None" 
                                   Foreground="#FF888888" FontSize="11" Margin="0,0,0,12"/>

                        <!-- Volume & Pan meters -->
                        <Grid Grid.Row="1" Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Volume -->
                            <Border Grid.Column="0" Background="#FF2D2D30" CornerRadius="4" Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="VOL" Foreground="#FF7881FF" FontSize="10" FontWeight="Bold" 
                                               VerticalAlignment="Center"/>

                                    <Slider x:Name="VolumeSlider" Grid.Column="1" 
                                            Minimum="0" Maximum="200" Value="100" 
                                            VerticalAlignment="Center" Margin="8,0"
                                            ValueChanged="VolumeChanged"/>

                                    <TextBlock x:Name="VolumeText" Grid.Column="2" Text="100%" 
                                               Foreground="White" FontSize="11" FontFamily="Consolas"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Pan -->
                            <Border Grid.Column="1" Background="#FF2D2D30" CornerRadius="4" Padding="12,10" Margin="10,0,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="PAN" Foreground="#FF7881FF" FontSize="10" FontWeight="Bold" 
                                               VerticalAlignment="Center"/>

                                    <Slider x:Name="PanSlider" Grid.Column="1" 
                                            Minimum="-100" Maximum="100" Value="0" 
                                            VerticalAlignment="Center" Margin="8,0"
                                            ValueChanged="PanChanged"/>

                                    <TextBlock x:Name="PanText" Grid.Column="2" Text="CENTER" 
                                               Foreground="White" FontSize="11" FontFamily="Consolas"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Effects panels -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- FILTERS -->
                                <Border Background="#FF2D2D30" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="FILTERS" Foreground="#FF9B59B6" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>

                                        <!-- Low Pass -->
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                            </Grid.ColumnDefinitions>

                                            <CheckBox x:Name="LowPassCheck" Content="Low Pass" Foreground="#FFCCCCCC" 
                                                      VerticalAlignment="Center" Click="LowPassClick"/>

                                            <Slider x:Name="LowPassSlider" Grid.Column="1" 
                                                    Minimum="200" Maximum="20000" Value="5000" 
                                                    VerticalAlignment="Center" Margin="10,0"
                                                    ValueChanged="LowPassChanged"/>

                                            <TextBlock x:Name="LowPassText" Grid.Column="2" Text="5000 Hz" 
                                                       Foreground="#FF7881FF" FontSize="10" FontFamily="Consolas"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>

                                        <!-- High Pass -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                            </Grid.ColumnDefinitions>

                                            <CheckBox x:Name="HighPassCheck" Content="High Pass" Foreground="#FFCCCCCC" 
                                                      VerticalAlignment="Center" Click="HighPassClick"/>

                                            <Slider x:Name="HighPassSlider" Grid.Column="1" 
                                                    Minimum="20" Maximum="5000" Value="200" 
                                                    VerticalAlignment="Center" Margin="10,0"
                                                    ValueChanged="HighPassChanged"/>

                                            <TextBlock x:Name="HighPassText" Grid.Column="2" Text="200 Hz" 
                                                       Foreground="#FF7881FF" FontSize="10" FontFamily="Consolas"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- EFFECTS -->
                                <Border Background="#FF2D2D30" CornerRadius="4" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="EFFECTS" Foreground="#FF9B59B6" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>

                                        <!-- Gain -->
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                            </Grid.ColumnDefinitions>

                                            <CheckBox x:Name="GainCheck" Content="Gain" Foreground="#FFCCCCCC" 
                                                      VerticalAlignment="Center" Click="GainClick"/>

                                            <Slider x:Name="GainSlider" Grid.Column="1" 
                                                    Minimum="-20" Maximum="20" Value="0" 
                                                    VerticalAlignment="Center" Margin="10,0"
                                                    ValueChanged="GainChanged"/>

                                            <TextBlock x:Name="GainText" Grid.Column="2" Text="0 dB" 
                                                       Foreground="#FF7881FF" FontSize="10" FontFamily="Consolas"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>

                                        <!-- Echo / Delay -->
                                        <CheckBox x:Name="EchoCheck" Content="Echo / Delay" Foreground="#FFCCCCCC" 
                                                  Margin="0,5" Click="EchoClick"/>

                                        <Grid Margin="20,5,0,10" x:Name="EchoPanel">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                <TextBlock Text="Delay" Foreground="#FF888888" FontSize="9"/>
                                                <Slider x:Name="EchoDelaySlider" Minimum="50" Maximum="1000" Value="300" ValueChanged="EchoChanged"/>
                                                <TextBlock x:Name="EchoDelayText" Text="300 ms" Foreground="#FF7881FF" FontSize="9" FontFamily="Consolas"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                                <TextBlock Text="Feedback" Foreground="#FF888888" FontSize="9"/>
                                                <Slider x:Name="EchoFeedbackSlider" Minimum="0" Maximum="90" Value="30" ValueChanged="EchoChanged"/>
                                                <TextBlock x:Name="EchoFeedbackText" Text="30%" Foreground="#FF7881FF" FontSize="9" FontFamily="Consolas"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Mix" Foreground="#FF888888" FontSize="9"/>
                                                <Slider x:Name="EchoMixSlider" Minimum="0" Maximum="100" Value="30" ValueChanged="EchoChanged"/>
                                                <TextBlock x:Name="EchoMixText" Text="30%" Foreground="#FF7881FF" FontSize="9" FontFamily="Consolas"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Reverb -->
                                        <CheckBox x:Name="ReverbCheck" Content="Reverb" Foreground="#FFCCCCCC" 
                                                  Margin="0,5" Click="ReverbClick"/>

                                        <Grid Margin="20,5,0,0" x:Name="ReverbPanel">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                <TextBlock Text="Wet" Foreground="#FF888888" FontSize="9"/>
                                                <Slider x:Name="ReverbWetSlider" Minimum="0" Maximum="100" Value="30" ValueChanged="ReverbChanged"/>
                                                <TextBlock x:Name="ReverbWetText" Text="30%" Foreground="#FF7881FF" FontSize="9" FontFamily="Consolas"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Room" Foreground="#FF888888" FontSize="9"/>
                                                <Slider x:Name="ReverbRoomSlider" Minimum="0" Maximum="100" Value="50" ValueChanged="ReverbChanged"/>
                                                <TextBlock x:Name="ReverbRoomText" Text="50%" Foreground="#FF7881FF" FontSize="9" FontFamily="Consolas"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Action buttons -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                                    <Button x:Name="PreviewBtn" Content="▶ Preview" Width="90" Margin="0,0,8,0" 
                                            Background="#FF4CAF50" Foreground="White" BorderThickness="0" Padding="10,8" Click="PreviewClick"/>
                                    <Button Content="Cancel" Width="80" Margin="0,0,8,0" Click="CancelClick"
                                            Background="#FF3E3E42" Foreground="White" BorderThickness="0" Padding="10,8"/>
                                    <Button Content="Apply" Width="80" Background="#FF4CAF50" Foreground="White" 
                                            BorderThickness="0" Padding="10,8" Click="ApplyClick"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </Border>
</Window>