<UserControl x:Class="AudioStudio.ClipControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="60">
    <Border x:Name="ClipBorder"
            Background="#3A3A3A"
            BorderBrush="#5A5A5A"
            BorderThickness="1"
            CornerRadius="4"
            Cursor="SizeAll">
        <Grid ClipToBounds="True">
            <!-- Waveform visualization - ВАЖНО: Stretch="Fill", Left aligned -->
            <Image x:Name="WaveformImage"
                   Stretch="Fill"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Stretch"/>
            
            <!-- Clip name -->
            <TextBlock Text="{Binding Name}"
                       Foreground="White"
                       FontSize="10"
                       FontWeight="Bold"
                       Margin="5,2"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Left"
                       TextTrimming="CharacterEllipsis"/>
            
            <!-- Selection indicator -->
            <Border x:Name="SelectedIndicator"
                    BorderBrush="#FF7881FF"
                    BorderThickness="2"
                    CornerRadius="4"
                    Visibility="Collapsed"
                    IsHitTestVisible="False"/>
        </Grid>
    </Border>
</UserControl>
